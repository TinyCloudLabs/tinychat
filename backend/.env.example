BACKEND_PRIVATE_KEY=
TINYCLOUD_HOST=https://node.tinycloud.xyz
PORT=3014
# FRONTEND_URL defaults to https://localhost:5186 when local certs exist.
# Use a trusted local cert for OpenKey/passkey flows. HTTPS with a certificate
# warning still blocks WebAuthn.
# FRONTEND_URL=http://localhost:5186
REDPILL_API_KEY=
REDPILL_BASE_URL=https://api.redpill.ai/v1
REDPILL_DEFAULT_MODEL=openai/gpt-5-mini

# ── Stripe subscription gating (paywall) ──────────────────────────────────────
# Master switch. Default false: NO gating — every request runs as today and is
# treated as the free tier with no limits enforced. Flip to true only once the
# Stripe vars below are filled in. See docs/stripe-setup.md.
PAYWALL_ENABLED=false

# Secret key from the Stripe dashboard (Developers → API keys).
# Use a test-mode key (sk_test_...) until you go live. When PAYWALL_ENABLED is
# true but this is empty, everyone resolves to the free tier and the
# checkout/portal endpoints return 503 billing_not_configured.
STRIPE_SECRET_KEY=

# Webhook signing secret (whsec_...) from the webhook endpoint you create in the
# Stripe dashboard pointing at /api/billing/webhook.
STRIPE_WEBHOOK_SECRET=

# Price IDs (price_...) for each paid tier + billing interval. Copy these from
# the Stripe dashboard after creating the Plus and Pro products with monthly and
# yearly recurring prices. The display prices shown in the UI live in
# backend/src/billing/tiers.ts; the real charge amounts come from these prices.
STRIPE_PRICE_PLUS_MONTHLY=
STRIPE_PRICE_PLUS_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=

# ── Credit budgets (optional; defaults baked into tiers.ts) ───────────────────
# Per-tier credit allowance. Free resets at UTC midnight (per-day). Paid tiers
# reset on a per-week window anchored to the subscriber's Stripe billing-cycle
# anchor (subscription-stable across renewals; falls back to current_period_start
# then created). Invalid/non-positive values fall back to the default with a
# console warning — misconfig must not zero out a user's budget. The peg and
# rate ladder are product semantics and stay as code constants (see
# docs/credits.md).
#
# NOTE: the old CREDIT_BUDGET_PLUS / CREDIT_BUDGET_PRO names are IGNORED — paid
# budgets are now per-week and read from the _WEEKLY-suffixed names below.
# CREDIT_BUDGET_FREE=500
# CREDIT_BUDGET_PLUS_WEEKLY=12000
# CREDIT_BUDGET_PRO_WEEKLY=28000

# ── Universal Ledger Credits sidecar ─────────────────────────────────────────
# URL of the billing sidecar (Cloudflare Worker). When unset the ledger
# feature is silently disabled (no 500, no user-visible error).
# IMPORTANT: the Phala CVM allowed_envs whitelist is frozen at creation —
# run updateCvmEnvs to add these two vars before deploying, or the ledger
# shadow-push and rehydration will not activate.
# LEDGER_SERVICE_URL=https://billing.tinycloud.xyz
# LEDGER_SERVICE_SECRET=
