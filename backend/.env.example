BACKEND_PRIVATE_KEY=
TINYCLOUD_HOST=https://node.tinycloud.xyz
PORT=3014
# FRONTEND_URL defaults to https://localhost:5186 when local certs exist.
# Use a trusted local cert for OpenKey/passkey flows. HTTPS with a certificate
# warning still blocks WebAuthn.
# FRONTEND_URL=http://localhost:5186
REDPILL_API_KEY=
REDPILL_BASE_URL=https://api.redpill.ai/v1
REDPILL_DEFAULT_MODEL=openai/gpt-5-mini
