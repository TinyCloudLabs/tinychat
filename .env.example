# Backend
BACKEND_PRIVATE_KEY=0x...  # Generate: bun run generate-key
# Optional backend TinyCloud node override (TEE node used in production)
# TINYCLOUD_HOST=https://node.tinycloud.xyz
FRONTEND_URL=https://localhost:5186
PORT=3014

# RedPill (confidential AI proxy used by POST /api/chat)
REDPILL_API_KEY=sk-rp-...
REDPILL_BASE_URL=https://api.redpill.ai/v1
REDPILL_DEFAULT_MODEL=openai/gpt-5-mini

# Frontend (Vite) — public config, baked at build time
VITE_OPENKEY_HOST=https://openkey.so
VITE_BACKEND_URL=https://localhost:3014

# Production defaults used for Cloudflare Pages / Phala examples:
# FRONTEND_URL=https://tinycloud.chat
# VITE_BACKEND_URL=https://api.tinycloud.chat
# TINYCLOUD_HOST=https://tee.node.tinycloud.xyz

# Phala backend deploy (see docs/deployment.md)
CLOUDFLARE_API_TOKEN=
CERTBOT_EMAIL=team@tinycloud.xyz
