# Baked into the production frontend build (vite loads .env.production in build
# mode). Public config only — no secrets. These must match the Production build
# environment variables set in the Cloudflare Pages dashboard (the source of
# truth for Git-integration builds; wrangler.toml [vars] do NOT feed the build).
VITE_OPENKEY_HOST=https://openkey.so
VITE_BACKEND_URL=https://api.tinycloud.chat
