VITE_OPENKEY_HOST=https://openkey.so

# VITE_BACKEND_URL is intentionally unset by default. The frontend derives it
# from the current page protocol:
# - http://localhost:5186 -> http://localhost:3014
# - https://localhost:5186 -> https://localhost:3014
#
# Uncomment this only when using trusted local certs for both dev servers.
# Do not run passkey/OpenKey flows on an HTTPS page with certificate errors;
# WebAuthn will be blocked even if the browser lets you click through.
# VITE_BACKEND_URL=https://localhost:3014
